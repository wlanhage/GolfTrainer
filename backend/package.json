{
  "name": "golftrainer-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "../prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:watch": "tsx --test --watch \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "node -r dotenv/config node_modules/prisma/build/index.js generate --schema ../prisma/schema.prisma",
    "prisma:db:push": "node -r dotenv/config node_modules/prisma/build/index.js db push --schema ../prisma/schema.prisma",
    "prisma:migrate:dev": "node -r dotenv/config node_modules/prisma/build/index.js migrate dev --schema ../prisma/schema.prisma",
    "prisma:studio": "node -r dotenv/config node_modules/prisma/build/index.js studio --schema ../prisma/schema.prisma --port 5555",
    "prisma:validate": "node -r dotenv/config node_modules/prisma/build/index.js validate --schema ../prisma/schema.prisma",
    "lint": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.4",
    "prisma": "^5.19.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
