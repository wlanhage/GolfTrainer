## Backend env (local development)
## Copy this file to `backend/.env` and fill in values (do NOT commit `.env`).

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
# Example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/golftrainer?schema=public
DATABASE_URL=

# JWT (min 32 chars each)
# Tip: use a password generator; keep these private.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes (ms-style, used by jsonwebtoken)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

