## Production environment (Render, Fly, etc.)
## Sätt dessa i din host's dashboard, INTE i en fil som checkas in.

NODE_ENV=production

# PORT injiceras av Render — du behöver inte sätta den, men ange fallback:
PORT=10000

# Supabase pooled connection (PgBouncer, port 6543) — för runtime queries
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Supabase direct connection (port 5432) — krävs för Prisma migrations
DIRECT_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-north-1.pooler.supabase.com:5432/postgres

# JWT secrets — generera starka strängar (min 32 tecken).
# På Render: använd `generateValue: true` i render.yaml så genereras de automatiskt.
JWT_ACCESS_SECRET=<minst 32 tecken slumpad sträng>
JWT_REFRESH_SECRET=<minst 32 tecken slumpad sträng>

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Tillåtna frontend-origins (komma-separerat, stödjer * som wildcard).
# Ex: "https://golftrainer.vercel.app,https://*.vercel.app"
CORS_ORIGINS=https://golftrainer.vercel.app,https://*.vercel.app
