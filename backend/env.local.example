## Local development database
## Copy to backend/.env.local and fill in values

NODE_ENV=development
PORT=3000

# Local PostgreSQL
DATABASE_URL=postgresql://postgres:<PASSWORD>@localhost:5432/golftrainer?schema=public

# JWT (min 32 chars each)
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_me_to_a_long_random_string_min_32_chars

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
