## Supabase development/remote database
## Copy to backend/.env.supabase and fill in values

NODE_ENV=development
PORT=3000

# Supabase Postgres connection string.
# In Supabase Dashboard: Project Settings -> Database -> Connection string -> URI (use direct connection).
# Replace <PROJECT_REF> and <DB_PASSWORD>. Include sslmode=require and schema=public.
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require&schema=public
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require&schema=public

# JWT (your app JWT secrets, not Supabase anon/service keys)
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_me_to_a_long_random_string_min_32_chars

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
