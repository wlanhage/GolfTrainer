generator client {
  provider = "prisma-client-js"
  // Generate Prisma Client into backend's node_modules so TypeScript in `backend/`
  // picks up the correct generated types (this repo is not using npm workspaces).
  // Prisma forbids generating directly into `@prisma/client`; it will forward imports
  // from `@prisma/client` to `.prisma/client` automatically.
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (PgBouncer, port 6543) — for runtime queries
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) — for migrations + introspection.
  // Required by Supabase pooler. Falls back to DATABASE_URL if not set.
  directUrl = env("DIRECT_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum ClubCategory {
  DRIVER
  WOOD
  HYBRID
  IRON
  WEDGE
  PUTTER
  OTHER
}

enum DominantHand {
  RIGHT
  LEFT
}

enum DrillMetricType {
  SUCCESS_RATE
  DISTANCE_CONTROL
  DISPERSION
  STROKES
  TIME_BASED
}

enum DistanceSampleSource {
  MANUAL
  LAUNCH_MONITOR
  GPS
  IMPORT
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum UserRole {
  USER
  PREMIUM_USER
  ADMIN
}

enum MissionScoreInputType {
  STEPPER
  MANUAL_NUMBER
}

enum MissionScoreDirection {
  DESC
  ASC
}

enum MissionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseSource {
  MANUAL
  IMPORTED
  USER_CREATED
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum HoleLayoutStatus {
  NOT_STARTED
  PARTIAL
  REQUIRED_COMPLETE
  FULL
}

enum RoundFormat {
  STROKE_PLAY
  STABLEFORD
  BEST_BALL_TEAM
  BEST_BALL_2V2
  FFA_STROKE
  FFA_STABLEFORD
  WOLF
}

enum WolfRole {
  WOLF
  PARTNER
  OPPONENT
}

enum RoundPlayStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum NotificationType {
  ROUND_STARTED
  NEW_FOLLOWER
  FRIEND_STARTED_ROUND
  FRIEND_FINISHED_NOTABLE
  PERSONAL_BEST
}

// ─── User ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile                 UserProfile?
  refreshTokens           RefreshToken[]
  userClubs               UserClub[]
  sessions                PracticeSession[]
  drillAttempts           DrillAttempt[]
  shotEntries             ShotEntry[]
  distanceSamples         UserClubDistanceSample[]
  distanceSnapshots       UserClubDistanceSnapshot[]
  metricSnapshots         UserMetricSnapshot[]
  recommendationLogs      RecommendationLog[]
  events                  DomainEvent[]
  createdDrills           Drill[]
  createdMissionTemplates MissionTemplate[]  @relation("MissionTemplateCreatedBy")
  missionEntries          MissionEntry[]
  courses                 Course[]
  rounds                  Round[]
  followers               UserFollow[]       @relation("UserFollowers")
  following               UserFollow[]       @relation("UserFollowing")
  pushSubscriptions       PushSubscription[]
  roundPlayers            RoundPlayer[]      @relation("UserRoundPlayers")
  notifications           Notification[]
}

model UserProfile {
  userId              String        @id
  displayName         String
  avatarImage         String?
  homeClub            String?
  city                String?
  country             String?
  dominantHand        DominantHand?
  handicap            Decimal?      @db.Decimal(4, 1)
  targetHandicap      Decimal?      @db.Decimal(4, 1)
  skillLevel          String?
  yearsPlaying        Int?
  roundsLast12Months  Int?
  trainingDaysPerWeek Int?
  favoriteClub        String?
  strengthArea        String?
  focusArea           String?
  goals               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenId           String    @unique // JWT jti
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  revokedReason     String?
  replacedByTokenId String?
  ip                String?
  userAgent         String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, revokedAt])
  @@index([expiresAt])
}

// ─── Notifications & Push ──────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  url       String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Social ────────────────────────────────────────────────────────────────

model UserFollow {
  id              String   @id @default(cuid())
  followerUserId  String   @map("follower_user_id")
  followingUserId String   @map("following_user_id")
  createdAt       DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerUserId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingUserId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, followingUserId])
  @@index([followerUserId, createdAt])
  @@index([followingUserId, createdAt])
  @@map("user_follows")
}

// ─── Caddy / Club data ─────────────────────────────────────────────────────

model ClubCatalog {
  id           String       @id @default(cuid())
  name         String
  category     ClubCategory
  loft         Decimal?     @db.Decimal(4, 1)
  manufacturer String?
  modelName    String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  userClubs UserClub[]

  @@index([category, isActive])
}

model UserClub {
  id            String   @id @default(cuid())
  userId        String
  clubCatalogId String?
  label         String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubCatalog       ClubCatalog?               @relation(fields: [clubCatalogId], references: [id], onDelete: SetNull)
  distanceSamples   UserClubDistanceSample[]
  distanceSnapshots UserClubDistanceSnapshot[]
  shotEntries       ShotEntry[]

  @@unique([userId, label])
  @@index([userId, isActive])
}

model UserClubDistanceSample {
  id               String               @id @default(cuid())
  userId           String
  userClubId       String
  carryMeters      Decimal              @db.Decimal(6, 2)
  totalMeters      Decimal?             @db.Decimal(6, 2)
  dispersionMeters Decimal?             @db.Decimal(6, 2)
  source           DistanceSampleSource
  notes            String?
  recordedAt       DateTime
  createdAt        DateTime             @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userClub UserClub @relation(fields: [userClubId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([userId, userClubId, recordedAt])
}

model UserClubDistanceSnapshot {
  id                String    @id @default(cuid())
  userId            String
  userClubId        String
  windowKey         String // e.g. "30d", "90d", "all"
  sampleSize        Int
  avgCarryMeters    Decimal   @db.Decimal(6, 2)
  p50CarryMeters    Decimal?  @db.Decimal(6, 2)
  p80CarryMeters    Decimal?  @db.Decimal(6, 2)
  stdDevCarryMeters Decimal?  @db.Decimal(6, 2)
  lastSampleAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userClub UserClub @relation(fields: [userClubId], references: [id], onDelete: Cascade)

  @@unique([userId, userClubId, windowKey])
  @@index([userId, updatedAt])
}

// ─── Practice / Drills ─────────────────────────────────────────────────────

model PracticeSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  focusArea String?
  notes     String?
  startedAt DateTime
  endedAt   DateTime?
  status    SessionStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  drillAttempts DrillAttempt[]
  shotEntries   ShotEntry[]

  @@index([userId, startedAt])
  @@index([userId, status, startedAt])
}

model Drill {
  id          String          @id @default(cuid())
  userId      String?
  name        String
  description String?
  metricType  DrillMetricType
  isPublic    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  drillAttempts DrillAttempt[]

  @@index([userId, createdAt])
  @@index([metricType, isPublic])
}

model DrillAttempt {
  id                String   @id @default(cuid())
  userId            String
  drillId           String
  practiceSessionId String?
  successCount      Int
  attemptCount      Int
  score             Decimal? @db.Decimal(8, 2)
  notes             String?
  attemptedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  drill           Drill            @relation(fields: [drillId], references: [id], onDelete: Restrict)
  practiceSession PracticeSession? @relation(fields: [practiceSessionId], references: [id], onDelete: SetNull)
  shotEntries     ShotEntry[]

  @@index([userId, attemptedAt])
  @@index([userId, drillId, attemptedAt])
}

model ShotEntry {
  id                 String   @id @default(cuid())
  userId             String
  practiceSessionId  String?
  drillAttemptId     String?
  userClubId         String
  carryMeters        Decimal? @db.Decimal(6, 2)
  totalMeters        Decimal? @db.Decimal(6, 2)
  launchDirectionDeg Decimal? @db.Decimal(6, 2)
  curveDeg           Decimal? @db.Decimal(6, 2)
  lieType            String?
  resultTag          String?
  notes              String?
  recordedAt         DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceSession PracticeSession? @relation(fields: [practiceSessionId], references: [id], onDelete: SetNull)
  drillAttempt    DrillAttempt?    @relation(fields: [drillAttemptId], references: [id], onDelete: SetNull)
  userClub        UserClub         @relation(fields: [userClubId], references: [id], onDelete: Restrict)

  @@index([userId, recordedAt])
  @@index([userId, userClubId, recordedAt])
  @@index([userId, practiceSessionId, recordedAt])
}

// ─── Analytics ──────────────────────────────────────────────────────────────

model UserMetricSnapshot {
  id            String   @id @default(cuid())
  userId        String
  metricKey     String
  metricVersion String   @default("v1")
  periodStart   DateTime
  periodEnd     DateTime
  valueNumeric  Decimal  @db.Decimal(12, 4)
  valueJson     Json?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, metricKey, periodStart])
  @@index([userId, createdAt])
}

model RecommendationLog {
  id                 String    @id @default(cuid())
  userId             String
  contextType        String
  contextJson        Json
  recommendationJson Json
  modelVersion       String
  acceptedAt         DateTime?
  feedbackJson       Json?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, modelVersion])
}

model DomainEvent {
  id            String   @id @default(cuid())
  userId        String?
  eventType     String
  aggregateType String?
  aggregateId   String?
  payloadJson   Json
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([userId, eventType, occurredAt])
}

// ─── Missions ──────────────────────────────────────────────────────────────

model MissionTemplate {
  id              String                @id @default(cuid())
  slug            String                @unique
  name            String
  description     String
  icon            String
  objective       String
  scoreLabel      String
  scoreInputType  MissionScoreInputType
  scoreDirection  MissionScoreDirection @default(DESC)
  stepperMin      Int?
  stepperMax      Int?
  defaultScore    Decimal?              @db.Decimal(8, 2)
  maxScore        Decimal?              @db.Decimal(8, 2)
  status          MissionStatus         @default(DRAFT)
  startsAt        DateTime?
  endsAt          DateTime?
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  createdBy   User             @relation("MissionTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  entries     MissionEntry[]
  leaderboard MissionLeaderboard?

  @@index([status, startsAt])
  @@index([createdByUserId, createdAt])
}

model MissionEntry {
  id                String   @id @default(cuid())
  missionTemplateId String
  userId            String
  score             Decimal  @db.Decimal(10, 2)
  notes             String?
  submittedAt       DateTime @default(now())
  createdAt         DateTime @default(now())

  missionTemplate MissionTemplate @relation(fields: [missionTemplateId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([missionTemplateId, userId, score])
  @@index([missionTemplateId, submittedAt])
  @@index([userId, submittedAt])
}

model MissionLeaderboard {
  id                String   @id @default(cuid())
  missionTemplateId String   @unique
  title             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  missionTemplate MissionTemplate @relation(fields: [missionTemplateId], references: [id], onDelete: Cascade)

  @@index([isActive, createdAt])
}

// ─── Courses ───────────────────────────────────────────────────────────────

model Course {
  id         String       @id @default(cuid())
  userId     String
  clubName   String
  courseName String
  teeName    String?
  holeCount  Int
  source     CourseSource @default(MANUAL)
  isDraft    Boolean      @default(false)
  localOnly  Boolean      @default(false)
  syncStatus SyncStatus   @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  holes  Hole[]
  rounds Round[]

  @@index([userId, updatedAt])
}

model Hole {
  id         String   @id @default(cuid())
  courseId   String
  holeNumber Int
  par        Int?
  length     Int?
  hcpIndex   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  holeLayout HoleLayout?
  roundHoles RoundHole[]

  @@unique([courseId, holeNumber])
}

model HoleLayout {
  id     String @id @default(cuid())
  holeId String @unique

  /// V1 provider-agnostic geometry model.
  teePoint       Json?
  greenPolygon   Json?
  fairwayPolygon Json?
  bunkerPolygons Json?
  treesPolygons  Json?
  obPolygons     Json?

  /// Derived V1 metadata.
  holeBearing          Decimal?         @map("hole_bearing") @db.Decimal(7, 3)
  holeLengthMeters     Decimal?         @map("hole_length_meters") @db.Decimal(8, 2)
  teeToGreenCenterline Json?            @map("tee_to_green_centerline")

  /// Single status column for mapping completeness.
  layoutStatus HoleLayoutStatus @default(NOT_STARTED) @map("layout_status")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hole Hole @relation(fields: [holeId], references: [id], onDelete: Cascade)
}

// ─── Rounds ────────────────────────────────────────────────────────────────

model Round {
  id                 String          @id @default(cuid())
  userId             String
  courseId           String
  startedAt          DateTime        @default(now())
  finishedAt         DateTime?
  currentHoleNumber  Int             @default(1)
  status             RoundPlayStatus @default(IN_PROGRESS)
  format             RoundFormat     @default(STROKE_PLAY)
  createdOffline     Boolean         @default(false)
  syncStatus         SyncStatus      @default(PENDING)
  teeNameSnapshot    String?
  courseNameSnapshot  String
  clubNameSnapshot   String
  totalScore         Int?
  image              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course        @relation(fields: [courseId], references: [id], onDelete: Restrict)
  roundHoles RoundHole[]
  players    RoundPlayer[]

  @@index([userId, startedAt])
  @@index([userId, totalScore])
  @@index([courseId, totalScore, startedAt])
  @@index([status, startedAt])
}

model RoundPlayer {
  id                  String    @id @default(cuid())
  roundId             String
  userId              String
  displayNameSnapshot String
  team                String?
  order               Int
  isHost              Boolean   @default(false)
  leftAt              DateTime?
  createdAt           DateTime  @default(now())

  round  Round            @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user   User             @relation("UserRoundPlayers", fields: [userId], references: [id], onDelete: Cascade)
  scores RoundHoleScore[]

  @@unique([roundId, order])
  @@unique([roundId, userId])
  @@index([userId])
}

model RoundHoleScore {
  id          String    @id @default(cuid())
  roundHoleId String
  playerId    String
  strokes     Int?
  wolfRole    WolfRole?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roundHole RoundHole   @relation(fields: [roundHoleId], references: [id], onDelete: Cascade)
  player    RoundPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([roundHoleId, playerId])
  @@index([playerId])
}

model RoundHole {
  id               String    @id @default(cuid())
  roundId          String
  holeId           String
  holeNumber       Int
  parSnapshot      Int?
  lengthSnapshot   Int?
  hcpIndexSnapshot Int?
  notes            String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  round  Round            @relation(fields: [roundId], references: [id], onDelete: Cascade)
  hole   Hole             @relation(fields: [holeId], references: [id], onDelete: Restrict)
  scores RoundHoleScore[]

  @@unique([roundId, holeNumber])
  @@index([roundId, holeId])
}
